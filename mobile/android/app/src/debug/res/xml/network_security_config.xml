<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-build-only network security config. Permits cleartext (http://)
  traffic so the app can reach a local-development NestJS backend (for
  example the Android emulator's host alias 10.0.2.2, or a LAN IP) without
  requiring TLS. This file lives under src/debug, so it is never merged
  into release or profile builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
