// This is the Relvio backend Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// Translated from the approved docs/12_Database_Design.md.
// Only entities and fields explicitly defined there are represented.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AttendanceStatus {
  Present
  Absent
  Late
}

enum UserStatus {
  ACTIVE
  DISABLED
}

model Organization {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  slug             String   @unique
  industry         String?
  logo             String?
  email            String?
  phone            String?
  address          String?
  country          String?
  timezone         String?
  subscriptionPlan String?  @map("subscription_plan")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  memberships      OrganizationMembership[]
  roles            Role[]
  people           Person[]
  tags             Tag[]
  journeyTemplates JourneyTemplate[]
  events           Event[]
  attendances      Attendance[]
  followUps        FollowUp[]
  notes            Note[]
  reports          Report[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("organizations")
}

// User is a global identity. It does not directly own organizationId or
// roleId; organization access and role assignment are represented by
// OrganizationMembership.
model User {
  id           String     @id @default(uuid()) @db.Uuid
  firstName    String     @map("first_name")
  lastName     String     @map("last_name")
  email        String     @unique
  passwordHash String     @map("password_hash")
  phone        String?
  status       UserStatus
  lastLogin    DateTime?  @map("last_login")
  deletedAt    DateTime?  @map("deleted_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  memberships             OrganizationMembership[]
  assignedPeople          Person[]                 @relation("PersonAssignedUser")
  journeyHistoryMoves     PersonJourneyHistory[]   @relation("JourneyHistoryMovedBy")
  eventsCreated           Event[]                  @relation("EventCreatedBy")
  attendancesCheckedIn    Attendance[]             @relation("AttendanceCheckedInBy")
  followUpsAssigned       FollowUp[]               @relation("FollowUpAssignedTo")
  notes                   Note[]
  reportsGenerated        Report[]                 @relation("ReportGeneratedBy")
  notifications           Notification[]
  auditLogs               AuditLog[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  @@index([phone])
  @@map("users")
}

// Supports refresh-token-based session renewal. Raw refresh tokens are never
// stored; only the cryptographic hash is stored. familyId supports revoking
// an entire refresh-token family after confirmed token reuse. revokedAt
// represents refresh-token revocation, including rotation and
// reuse-triggered family revocation.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

// Supports single-use email verification. Raw verification tokens are never
// stored; only the cryptographic hash is stored. usedAt represents
// single-use token consumption.
model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("email_verification_tokens")
}

// Supports single-use password reset. Raw reset tokens are never stored;
// only the cryptographic hash is stored. usedAt represents single-use token
// consumption.
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

// Role remains organization-owned. The compound unique key (id,
// organizationId) exists solely so OrganizationMembership can form a
// composite foreign key that structurally guarantees a membership's role
// belongs to the same organization as the membership.
model Role {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  description    String?

  organization    Organization             @relation(fields: [organizationId], references: [id])
  memberships     OrganizationMembership[]
  rolePermissions RolePermission[]

  @@unique([id, organizationId])
  @@index([organizationId])
  @@map("roles")
}

model Permission {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Represents one User's membership in one Organization, with a role scoped
// to that membership. Unique per (organizationId, userId). The role
// relation is a composite foreign key on (roleId, organizationId) referencing
// Role's (id, organizationId), so the database rejects any membership whose
// role belongs to a different organization.
model OrganizationMembership {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  roleId         String   @map("role_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId, organizationId], references: [id, organizationId])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("organization_memberships")
}

model Person {
  id                    String    @id @default(uuid()) @db.Uuid
  organizationId        String    @map("organization_id") @db.Uuid
  firstName             String    @map("first_name")
  lastName              String    @map("last_name")
  gender                String?
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  phone                 String?
  email                 String?
  address               String?
  occupation            String?
  profilePhoto          String?   @map("profile_photo")
  currentJourneyStageId String?   @map("current_journey_stage_id") @db.Uuid
  assignedUserId        String?   @map("assigned_user_id") @db.Uuid
  status                String
  deletedAt             DateTime? @map("deleted_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  organization        Organization  @relation(fields: [organizationId], references: [id])
  currentJourneyStage JourneyStage? @relation(fields: [currentJourneyStageId], references: [id])
  assignedUser        User?         @relation("PersonAssignedUser", fields: [assignedUserId], references: [id])

  attendances    Attendance[]
  notes          Note[]
  journeyHistory PersonJourneyHistory[]
  followUps      FollowUp[]
  personTags     PersonTag[]

  @@index([organizationId])
  @@index([phone])
  @@map("people")
}

model Tag {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  color          String?

  organization Organization @relation(fields: [organizationId], references: [id])
  personTags   PersonTag[]

  @@index([organizationId])
  @@map("tags")
}

model PersonTag {
  personId String @map("person_id") @db.Uuid
  tagId    String @map("tag_id") @db.Uuid

  person Person @relation(fields: [personId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([personId, tagId])
  @@map("person_tags")
}

model JourneyTemplate {
  id             String  @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  name           String
  description    String?

  organization Organization   @relation(fields: [organizationId], references: [id])
  stages       JourneyStage[]

  @@index([organizationId])
  @@map("journey_templates")
}

model JourneyStage {
  id                String @id @default(uuid()) @db.Uuid
  journeyTemplateId String @map("journey_template_id") @db.Uuid
  name              String
  order             Int

  journeyTemplate JourneyTemplate @relation(fields: [journeyTemplateId], references: [id])

  peopleCurrentlyHere Person[]
  historyAsFromStage  PersonJourneyHistory[] @relation("JourneyHistoryFromStage")
  historyAsToStage    PersonJourneyHistory[] @relation("JourneyHistoryToStage")

  @@index([journeyTemplateId])
  @@map("journey_stages")
}

// Append-only journey transition history. No updatedAt, no deletedAt: records
// must never be modified after creation. Immutability itself (preventing
// UPDATE/DELETE against existing rows) remains an application/service-level
// responsibility; see completion report.
model PersonJourneyHistory {
  id          String   @id @default(uuid()) @db.Uuid
  personId    String   @map("person_id") @db.Uuid
  fromStageId String?  @map("from_stage_id") @db.Uuid
  toStageId   String   @map("to_stage_id") @db.Uuid
  movedBy     String?  @map("moved_by") @db.Uuid
  movedAt     DateTime @map("moved_at")
  notes       String?

  person      Person        @relation(fields: [personId], references: [id])
  fromStage   JourneyStage? @relation("JourneyHistoryFromStage", fields: [fromStageId], references: [id])
  toStage     JourneyStage  @relation("JourneyHistoryToStage", fields: [toStageId], references: [id])
  movedByUser User?         @relation("JourneyHistoryMovedBy", fields: [movedBy], references: [id])

  @@index([personId])
  @@map("person_journey_history")
}

model Event {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  title          String
  description    String?
  category       String?
  venue          String?
  startDate      DateTime  @map("start_date")
  endDate        DateTime? @map("end_date")
  createdBy      String    @map("created_by") @db.Uuid
  cancelledAt    DateTime? @map("cancelled_at")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization @relation(fields: [organizationId], references: [id])
  createdByUser User         @relation("EventCreatedBy", fields: [createdBy], references: [id])

  attendances Attendance[]

  @@index([organizationId])
  @@map("events")
}

// Attendance duplicate-prevention / idempotency boundary, exactly as
// approved: unique on (organizationId, eventId, personId).
model Attendance {
  id             String           @id @default(uuid()) @db.Uuid
  eventId        String           @map("event_id") @db.Uuid
  personId       String           @map("person_id") @db.Uuid
  status         AttendanceStatus
  checkedInBy    String?          @map("checked_in_by") @db.Uuid
  checkedInAt    DateTime         @map("checked_in_at")
  organizationId String           @map("organization_id") @db.Uuid

  event           Event        @relation(fields: [eventId], references: [id])
  person          Person       @relation(fields: [personId], references: [id])
  organization    Organization @relation(fields: [organizationId], references: [id])
  checkedInByUser User?        @relation("AttendanceCheckedInBy", fields: [checkedInBy], references: [id])

  @@unique([organizationId, eventId, personId])
  @@index([organizationId, personId])
  @@index([organizationId, eventId])
  @@map("attendance")
}

model FollowUp {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  personId       String    @map("person_id") @db.Uuid
  assignedTo     String?   @map("assigned_to") @db.Uuid
  title          String
  description    String?
  dueDate        DateTime? @map("due_date")
  status         String
  completedAt    DateTime? @map("completed_at")

  organization   Organization @relation(fields: [organizationId], references: [id])
  person         Person       @relation(fields: [personId], references: [id])
  assignedToUser User?        @relation("FollowUpAssignedTo", fields: [assignedTo], references: [id])

  @@index([organizationId])
  @@index([personId])
  @@map("follow_ups")
}

model Note {
  id             String   @id @default(uuid()) @db.Uuid
  personId       String   @map("person_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  note           String
  createdAt      DateTime @default(now()) @map("created_at")
  organizationId String   @map("organization_id") @db.Uuid

  person       Person       @relation(fields: [personId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, personId])
  @@map("notes")
}

model Report {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  reportName     String   @map("report_name")
  generatedBy    String?  @map("generated_by") @db.Uuid
  generatedAt    DateTime @map("generated_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  generatedByUser User?        @relation("ReportGeneratedBy", fields: [generatedBy], references: [id])

  @@index([organizationId])
  @@map("reports")
}

model Notification {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String
  message        String
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@map("notifications")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  entity         String
  entityId       String   @map("entity_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}
